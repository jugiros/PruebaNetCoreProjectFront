# Copia este archivo como .env.local y ajusta los valores para tu entorno local.
# .env.local NUNCA se sube al repositorio (está en .gitignore).

# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* → Expuesta al browser (bundle cliente).
# Usar SOLO para endpoints públicos (login, register) que no requieren JWT.
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_API_URL=http://localhost:5010

# ──────────────────────────────────────────────────────────────────────────────
# Sin prefijo NEXT_PUBLIC → Solo disponible en el servidor (Server Components,
# Route Handlers / BFF). El JWT nunca llega al browser. Patrón BFF obligatorio
# para endpoints autenticados: balance, transfers, etc.
# ──────────────────────────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:5010
